#: dist/translation-strings.php:2112
#: dist/premium-guided-tours.js:1
#: dist/translation-strings.js:407
msgid "Click the <strong>Preview</strong> button on the top toolbar."
msgstr ""

#: dist/translation-strings.php:2113
#: dist/premium-guided-tours.js:1
#: dist/translation-strings.js:408
