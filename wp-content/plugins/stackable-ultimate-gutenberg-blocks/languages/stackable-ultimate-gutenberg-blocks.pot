#: dist/premium-guided-tours.js:1
#: dist/translation-strings.js:401
msgid "Let's add a new condition to control when this block is shown. You can pick one or more conditions to fit your needs."
msgstr ""

#: dist/translation-strings.php:2107
#: dist/premium-guided-tours.js:1
#: dist/translation-strings.js:402
msgid "Click on <strong>Add Condition</strong> to begin setting your display rules."
