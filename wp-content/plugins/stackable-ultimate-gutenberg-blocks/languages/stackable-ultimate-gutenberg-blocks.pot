#: dist/translation-strings.php:2110
#: dist/premium-guided-tours.js:1
#: dist/translation-strings.js:405
msgid "Preview as Logged In User"
msgstr ""

#: dist/translation-strings.php:2111
#: dist/premium-guided-tours.js:1
#: dist/translation-strings.js:406
msgid "Let's check your settings by previewing the page. You should see the content since you're logged in."
