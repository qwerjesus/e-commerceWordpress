#: dist/translation-strings.php:2066
#: dist/premium-guided-tours.js:1
#: dist/translation-strings.js:361
msgid "In this quick guide, you'll learn how to save and apply styles between blocks using Stackable's Block Styles feature. This will help you design faster and keep your site consistent."
msgstr ""

#: dist/translation-strings.php:2067
#: dist/premium-guided-tours.js:1
#: dist/translation-strings.js:362
msgid "Click <strong>Next</strong> to start."
msgstr ""

#: dist/translation-strings.php:2068
#: dist/premium-guided-tours.js:1
#: dist/translation-strings.js:363
msgid "Open Block Styles"
msgstr ""

#: dist/translation-strings.php:2069
#: dist/premium-guided-tours.js:1
#: dist/translation-strings.js:364
msgid "Your page has two columns: the first is styled with custom options, and the second uses default settings. With Block Styles, you can easily re-use the style from one column to the other."
msgstr ""

#: dist/translation-strings.php:2070
#: dist/premium-guided-tours.js:1
#: dist/translation-strings.js:365
msgid "Click the <strong>Block Styles</strong> button in the Inspector sidebar."
msgstr ""

#: dist/translation-strings.php:2071
#: dist/premium-guided-tours.js:1
#: dist/translation-strings.js:366
msgid "Save This Column as a Block Style"
msgstr ""

#: dist/translation-strings.php:2072
#: dist/premium-guided-tours.js:1
#: dist/translation-strings.js:367
msgid "Let's save how this column looks as a reusable Block Style so you can apply it again anytime you want."
msgstr ""

#: dist/translation-strings.php:2073
#: dist/premium-guided-tours.js:1
#: dist/translation-strings.js:368
msgid "Click <strong>Add New</strong> in the Block Styles popup."
msgstr ""

#: dist/translation-strings.php:2074
#: dist/premium-guided-tours.js:1
#: dist/translation-strings.js:369
msgid "Name and Save Your Style"
msgstr ""

#: dist/translation-strings.php:2075
#: dist/premium-guided-tours.js:1
#: dist/translation-strings.js:370
msgid "Give your new Block Style a name, like \"Big Shadow\". This makes it available for use anywhere in your site."
msgstr ""

#: dist/translation-strings.php:2076
#: dist/premium-guided-tours.js:1
#: dist/translation-strings.js:371
msgid "Enter <strong>Big Shadow</strong> as the name, then click <strong>Create Block Style</strong>."
msgstr ""

#: dist/translation-strings.php:2077
#: dist/premium-guided-tours.js:1
#: dist/translation-strings.js:372
msgid "Select the Second Column"
msgstr ""

#: dist/translation-strings.php:2078
#: dist/premium-guided-tours.js:1
#: dist/translation-strings.js:373
msgid "Now, let's use your newly-saved style! Click the second column in the editor to select it."
msgstr ""

#: dist/translation-strings.php:2079
#: dist/premium-guided-tours.js:1
#: dist/translation-strings.js:374
msgid "Click on the second inner <strong>Column</strong> block in your Columns layout."
msgstr ""

#: dist/translation-strings.php:2080
#: dist/premium-guided-tours.js:1
#: dist/translation-strings.js:375
msgid "Open Block Styles for the Second Column"
msgstr ""

#: dist/translation-strings.php:2081
#: dist/premium-guided-tours.js:1
#: dist/translation-strings.js:376
msgid "Let's apply your saved Block Style! Open the \"Block Styles\" popup for the second column."
msgstr ""

#: dist/translation-strings.php:2082
#: dist/premium-guided-tours.js:1
#: dist/translation-strings.js:377
msgid "Click the <strong>Block Styles</strong> button again in the Inspector sidebar."
msgstr ""

#: dist/translation-strings.php:2083
#: dist/premium-guided-tours.js:1
#: dist/translation-strings.js:378
msgid "Apply Your Saved Block Style"
msgstr ""

#: dist/translation-strings.php:2084
#: dist/premium-guided-tours.js:1
#: dist/translation-strings.js:379
msgid "Choose \"Big Shadow\" from the list of available Block Styles. Clicking it will instantly copy the same look over to the second column!"
msgstr ""

#: dist/translation-strings.php:2085
#: dist/premium-guided-tours.js:1
#: dist/translation-strings.js:380
msgid "Click the <strong>Big Shadow</strong> Block Style to apply it."
msgstr ""

#: dist/translation-strings.php:2086
#: dist/premium-guided-tours.js:1
#: dist/translation-strings.js:381
msgid "Column Styles Are Now Identical"
msgstr ""

#: dist/translation-strings.php:2087
#: dist/premium-guided-tours.js:1
#: dist/translation-strings.js:382
msgid "Success! Both columns have the same style now. Re-using Block Styles is a huge time saver and keeps your layouts visually consistent."
msgstr ""

#: dist/translation-strings.php:2088
#: dist/premium-guided-tours.js:1
#: dist/translation-strings.js:383
msgid "Modifying Block Styles"
msgstr ""

#: dist/translation-strings.php:2089
#: dist/premium-guided-tours.js:1
#: dist/translation-strings.js:384
msgid "Want to tweak your style? Let's say changed our minds and want a sharper style. Open \"Container Borders & Shadows\" and set the Border Radius to zero."
msgstr ""

#: dist/translation-strings.php:2090
#: dist/premium-guided-tours.js:1
#: dist/translation-strings.js:385
msgid "In the <strong>Style</strong> tab, set the <strong>Container Border Radius</strong> to <strong>0</strong>."
msgstr ""

#: dist/translation-strings.php:2091
#: dist/premium-guided-tours.js:1
#: dist/translation-strings.js:386
msgid "Update All Block Styles"
msgstr ""

#: dist/translation-strings.php:2092
#: dist/premium-guided-tours.js:1
#: dist/translation-strings.js:387
msgid "The change we did only affected this one block, but if you want all \"Big Shadow\" Block Styles to reflect your recent changes, we will need to update our Block Style."
msgstr ""

#: dist/translation-strings.php:2093
#: dist/premium-guided-tours.js:1
#: dist/translation-strings.js:388
msgid "Open <strong>Block Styles</strong> again in the Inspector sidebar."
msgstr ""

#: dist/translation-strings.php:2094
#: dist/premium-guided-tours.js:1
#: dist/translation-strings.js:389
msgid "Update the Block Style Across Your Site"
msgstr ""

#: dist/translation-strings.php:2095
#: dist/premium-guided-tours.js:1
#: dist/translation-strings.js:390
msgid "Click \"Update Block Style\" so your changes apply everywhere you used \"Big Shadow\". All blocks with this style will update instantly!"
msgstr ""

#: dist/translation-strings.php:2096
#: dist/premium-guided-tours.js:1
#: dist/translation-strings.js:391
msgid "Click the <strong>Update Block Style</strong> button."
msgstr ""

#: dist/translation-strings.php:2097
#: dist/premium-guided-tours.js:1
#: dist/translation-strings.js:392
msgid "Confirm the Update"
msgstr ""

#: dist/translation-strings.php:2098
#: dist/premium-guided-tours.js:1
#: dist/translation-strings.js:393
msgid "You're almost done! Now let's confirm updating the Block Style so all blocks using \"Big Shadow\" get these changes."
msgstr ""

#: dist/translation-strings.php:2099
#: dist/premium-guided-tours.js:1
#: dist/translation-strings.js:394
msgid "Click the <strong>Update Block Style</strong> button to apply your changes everywhere."
msgstr ""

#: dist/translation-strings.php:2100
#: dist/premium-guided-tours.js:1
#: dist/translation-strings.js:395
msgid "Tip: Manage All Block Styles in One Place"
msgstr ""

#: dist/translation-strings.php:2101
#: dist/premium-guided-tours.js:1
#: dist/translation-strings.js:396
msgid "Want to edit or delete Block Styles you've created? Head to <strong>Stackable Design System > Global Block Styles</strong> anytime to manage your saved styles."
msgstr ""

#: dist/translation-strings.php:2102
#: dist/premium-guided-tours.js:1
#: dist/translation-strings.js:397
msgid "Conditional Display: Show or Hide Content by Condition"
msgstr ""

#: dist/translation-strings.php:2103
#: dist/premium-guided-tours.js:1
#: dist/translation-strings.js:398
msgid "Conditional display lets you show or hide content based on a variety of conditions, such as user roles, login status, date, post type, and more. Use it to tailor your page by showing different content to different visitors according to your chosen rules."
msgstr ""

#: dist/translation-strings.php:2104
#: dist/premium-guided-tours.js:1
#: dist/translation-strings.js:399
msgid "Click the <strong>Advanced Tab</strong> in the sidebar to start setting your custom rules."
msgstr ""

#: dist/translation-strings.php:2105
#: dist/premium-guided-tours.js:1
#: dist/translation-strings.js:400
msgid "Adding New Conditions"
msgstr ""

